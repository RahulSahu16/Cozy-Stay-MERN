<%- include('../partials/head') %>
</head>

<body class="bg-gray-50 min-h-screen flex flex-col">

    <%- include('../partials/navbar') %>
    
    <% if (registeredHomes && registeredHomes.length > 0) { %>

    <!-- Centered Heading -->
    <div class="text-center mb-8">
        <h2 class="text-3xl mt-8 font-bold text-gray-800 tracking-wide">
            Here All The Hosted Homes
        </h2>

        <!-- Decorative Line -->
        <div class="w-24 h-1 bg-indigo-600 mx-auto mt-2 rounded"></div>

        <!-- Subtitle (optional but looks premium) -->
        <p class="text-gray-500 mt-2 text-sm">
           
        </p>
    </div>

    <!-- Flex Container -->
    <div class="flex flex-wrap gap-6 justify-center">

        <% registeredHomes.forEach((home, index) => { %>
            
            <!-- Card -->
            <div class="w-full sm:w-[300px] bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-2xl transition duration-300">

                <!-- Image -->
                <img 
                    src="/uploads/<%= home.imageURL %>" 
                    alt="<%= home.houseName %>" 
                    class="w-full h-48 object-cover"
                >

                <!-- Content -->
                <div class="p-4">
                    <h3 class="text-lg font-semibold text-indigo-600 mb-1">
                        <%= home.houseName %>
                    </h3>

                    <p class="text-gray-600 text-sm mb-1">
                        📍 <%= home.city %>
                    </p>

                    <p class="text-gray-700 font-medium">
                        ₹ <%= home.price %> / night
                    </p>

                    <p class="text-yellow-500 text-sm mb-4">
                        ⭐ <%= home.rating %>
                    </p>

                    <!-- Buttons -->
                    <div class="flex flex-col gap-2">

                        <!-- Edit Details -->
                        <a href="/host/editHome/<%= home._id %>?editing=true" 
                           class="text-center bg-yellow-300 text-indigo-600 py-2 rounded-lg font-medium hover:bg-yellow-500 transition">
                            Edit Details
                        </a>
                        <form action="/host/deleteHome/<%= home._id %>" method="POST">
                          <button 
                            type="submit"
                            class="w-full text-center bg-red-500 text-white py-2 rounded-lg font-medium hover:bg-red-600 transition"
                            onclick="return confirm('Are you sure you want to delete this house?')"
                            >
                             Delete Home
                          </button>
                        </form>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } else { %>
    <p class="text-center text-gray-500">No homes added yet.</p>
<% } %>

</body>
</html>
