<%- include('../partials/head') %>
</head>

<body class="bg-gray-100 min-h-screen">

    <!-- Navbar (Cozy Stay Theme) -->
    <%- include('../partials/navbar') %>

    <!-- Form Section -->
    <div class="flex justify-center items-center mt-10 px-4">

        <div class="bg-white shadow-lg rounded-xl p-8 w-full max-w-2xl">

            <h2 class="text-3xl font-bold text-center text-blue-600 mb-6">
                <%= editing ? "Edit Your Home" : "Add Your Home" %>
            </h2>
            
            <form action="<%= editing ? '/host/editHome' : '/host/addHome' %>" method="POST" enctype="multipart/form-data" class="space-y-5">

                <% if (editing) { %>
                    <input type="hidden" name="homeId" value="<%= home._id %>">
                <% } %>

                <!-- House Name -->
                <div>

                    <label class="block font-medium mb-1">House Name</label>
                    <input 
                        type="text" 
                        name="houseName"
                        placeholder="Enter the name of your house"
                        class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        value="<%= editing ? home.houseName : '' %>"
                        required

                    >
                </div>
 
                <div>
                    <label class="block font-medium mb-1">City</label>
                    <input 
                        type="text" 
                        name="city"
                        placeholder="Enter the city "
                        class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        value="<%= editing ? home.city : '' %>"
                        required
                    >
                </div> 

                <!-- Price -->
                <div>
                    <label class="block font-medium mb-1">Price (₹ / night)</label>
                    <input 
                        type="number" 
                        name="price"
                        placeholder="Enter the rent of the house in Rs"
                        class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        value="<%= editing ? home.price : '' %>"
                        required
                    >
                </div>

                <!-- Rating -->
                <div>
                    <label class="block font-medium mb-1">Rating (0–5)</label>
                    <input 
                        type="number" 
                        name="rating"
                        step="1"
                        min="0"
                        max="5"
                        placeholder="Give your rating"
                        class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        value="<%= editing ? home.rating : '' %>"
                        required
                    >
                </div> 

                <!-- Image URL -->
                <div>
                    <label class="block font-medium mb-1">Image URL</label>
                    <input 
                        type="file" 
                        name="image"
                        class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        <%= editing ? '' : 'required' %>
                    >
                </div>

                <!-- Description -->
                <div>
                    <label class="block font-medium mb-1">Description</label>
                    <textarea 
                       name="description"
                       rows="4"
                       placeholder="Enter the description of your house"
                       class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
                       required
                       ><%= editing ? home.description : '' %></textarea>
                </div> 

                <!-- Submit Button -->
                <button 
                    type="submit"
                    class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition font-semibold"
                >
                    <%= editing ? "Update Home" : "Add Home" %>
                </button>

            </form>

        </div>

    </div>

</body>
</html>

