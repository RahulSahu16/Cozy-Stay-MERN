<%- include('../partials/head') %>
</head>

<body class="min-h-screen flex flex-col bg-gray-50">

<!-- Navbar -->
<%- include('../partials/navbar') %>


<!-- Hero Section -->
<main class="flex-grow relative overflow-hidden 
             bg-gradient-to-br from-pink-100 via-indigo-100 to-blue-100 flex items-center justify-center">

    <!-- Decorative Background Shapes -->
    <div class="absolute w-96 h-96 bg-pink-200 rounded-full blur-3xl opacity-40 -top-20 -left-20"></div>
    <div class="absolute w-96 h-96 bg-indigo-200 rounded-full blur-3xl opacity-40 bottom-0 right-0"></div>

    <!-- Content -->
    <div class="relative text-center px-6 max-w-3xl">

        <h2 class="text-5xl md:text-6xl font-extrabold text-gray-800 leading-tight mb-6">
            Find Your Perfect Stay with  
            <span class="text-indigo-600">Cozy Stay</span>
        </h2>

        <p class="text-gray-600 text-lg md:text-xl mb-10">
            Explore beautiful homes, save your favourites, or host your property easily.  
            Simple. Comfortable. Reliable.
        </p>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center">

            <a href="/allhomes"
               class="bg-indigo-600 text-white px-8 py-4 rounded-xl text-lg font-semibold 
                      hover:bg-indigo-700 transition shadow-lg hover:shadow-xl transform hover:-translate-y-1">
                Explore Homes
            </a>

            <a href="/host/addHome"
               class="bg-white text-indigo-600 border border-indigo-600 px-8 py-4 rounded-xl text-lg font-semibold 
                      hover:bg-indigo-50 transition shadow-md hover:shadow-lg transform hover:-translate-y-1">
                List Your Property
            </a>

        </div>

    </div>

</main>


<!-- Footer -->
<footer class="bg-white text-center py-4 text-gray-500 shadow-inner">
    © 2026 Cozy Stay. All rights reserved.
</footer>

</body>
</html>