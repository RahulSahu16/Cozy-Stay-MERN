<nav class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

        <!-- Logo -->
        <h1 class="text-2xl font-bold text-indigo-600 pl-2">
            <a href="/">Cozy Stay</a>
        </h1>

        <!-- Menu -->
        <div class="space-x-6 hidden md:flex items-center">

            <a href="/allhomes"
               class="px-4 py-2 border border-indigo-600 text-indigo-600 rounded-lg font-medium hover:bg-indigo-50 transition">
                All Homes
            </a>

            <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>

                <!-- Favourites -->
                <a href="/favourites"
                   class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition shadow">
                    Favourites
                </a>

                <!-- HOST FEATURES -->
                <% if (user && user.role === "host") { %>

                    <a href="/host/addHome"
                       class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition shadow">
                        Add Home
                    </a>

                    <a href="/host/hostHome"
                       class="px-4 py-2 border border-indigo-600 text-indigo-600 rounded-lg font-medium hover:bg-indigo-50 transition">
                        Manage Homes
                    </a>

                <% } else { %>

                    <!-- Become Host -->
                    <a href="/become-host"
                       class="px-4 py-2 border border-indigo-600 text-indigo-600 rounded-lg font-medium hover:bg-indigo-50 transition">
                        Become Host
                    </a>

                <% } %>

                <!-- Logout -->
                <form action="/logout" method="POST" class="inline">
                    <button type="submit"
                        class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition shadow">
                        Logout
                    </button>
                </form>

            <% } else { %>

                <!-- Login -->
                <a href="/login"
                   class="px-4 py-2 bg-green-600 text-white rounded-lg font-medium hover:bg-green-700 transition shadow">
                    Login
                </a>

            <% } %>

        </div>
    </div>
</nav>